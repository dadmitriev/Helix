# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=diabetes_user
POSTGRES_PASSWORD=diabetes_secret
POSTGRES_DB=diabetes_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Async DSN for SQLAlchemy
DATABASE_URL=postgresql+asyncpg://diabetes_user:diabetes_secret@db:5432/diabetes_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_change_in_production_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Allows CORS from frontend
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ─── Admin seed user (created on first startup) ───────────────────────────────
FIRST_ADMIN_EMAIL=admin@clinic.local
FIRST_ADMIN_PASSWORD=Admin123!
FIRST_ADMIN_FIRST_NAME=System
FIRST_ADMIN_LAST_NAME=Administrator

# ─── ML ───────────────────────────────────────────────────────────────────────
ML_MODELS_DIR=app/ml/models
ML_MODEL_NAME=pipeline_v1.joblib
